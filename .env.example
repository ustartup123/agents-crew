# ─── Gemini API ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash          # or gemini-2.0-pro

# ─── Slack ────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Slack channel IDs — run setup_slack_channel.py to create and auto-fill these
SLACK_CHANNEL_STANDUP=C0123456789       # #ai-team-standup  ← set automatically by setup script
SLACK_CHANNEL_GENERAL=C0123456789       # #ai-team-general
SLACK_CHANNEL_ENGINEERING=C0123456789   # #ai-team-engineering
SLACK_CHANNEL_BUSINESS=C0123456789      # #ai-team-business
SLACK_CHANNEL_EXECUTIVE=C0123456789     # #ai-team-executive

# ─── Notion ───────────────────────────────────────────────────
NOTION_API_KEY=secret_your-notion-integration-token
NOTION_ROOT_PAGE_ID=your-root-page-id   # Parent page for all agent work

# ─── E2B (Code Execution Sandbox) ────────────────────────
E2B_API_KEY=e2b_xxxx

# ─── GitHub ──────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxx
GITHUB_USERNAME=your-github-username

# ─── App Settings ─────────────────────────────────────────────
STARTUP_NAME=MyStartup
STARTUP_IDEA=A SaaS tool that helps indie developers automatically generate and A/B test app store listings using AI
LOG_LEVEL=INFO
